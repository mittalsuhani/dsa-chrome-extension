{
  "manifest_version": 3,
  "name": "LeetCode Dynamic Hints",
  "version": "2.0",
  "description": "Automatically fetches official hints for any LeetCode problem dynamically.",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://leetcode.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Show Problem Hints"
  },
  "content_scripts": [
    {
      "matches": [
        "*://leetcode.com/problems/*",
        "*://*.leetcode.com/problems/*"
      ],
      "js": ["content.js"]
    }
  ]
}